{
  "schema_version": 1,
  "mixin": [
    "examplemod.mixins.json",
    "examplemod-common.mixins.json"
  ],
  "quilt_loader": {
    "group": "${group}",
    "id": "examplemod",
    "version": "${version}",
    "metadata": {
      "name": "Example Mod",
      "description": "This is an example description! Tell everyone what your mod is about!",
      "contributors": {
        "Me!": "Owner"
      },
      "icon": "assets/examplemod/icon.png"
    },
    "intermediate_mappings": "net.fabricmc:intermediary",
    "entrypoints": {
      "init": [
        "com.example.examplemod.quilt.ExampleModQuilt"
      ]
    },
    "depends": [
      {
        "id": "quilt_loader",
        "version": "*"
      },
      {
        "id": "quilt_base",
        "version": "*"
      },
      {
        "id": "minecraft",
        "version": ">=1.20.2"
      }
    ]
  },
  "minecraft": {
    "environment": "*"
  }
}